{
  "name": "monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others --raw \"npm run dev --prefix web\" \"npm run dev --prefix pocketbase\"",
    "build": "concurrently --raw \"npm run build --prefix web\"",
    "start": "concurrently --kill-others --raw \"npm run start --prefix pocketbase\"",
    "lint": "concurrently --raw \"npm run lint --prefix web\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "pocketbase": "^0.22.0"
  },
  "workspaces": [
    "web",
    "pocketbase"
  ],
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1"
  }
}
